{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.turbo/**",
        "!dist/**",
        "!.svelte-kit/**",
        "!node_modules/.vite/**",
        "!tsconfig.tsbuildinfo"
      ],
      "outputs": ["dist/**", ".svelte-kit/output/**", ".astro/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.turbo/**",
        "!dist/**",
        "!.svelte-kit/**",
        "!node_modules/.vite/**",
        "!tsconfig.tsbuildinfo"
      ]
    },
    "check": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.turbo/**",
        "!dist/**",
        "!.svelte-kit/**",
        "!node_modules/.vite/**",
        "!tsconfig.tsbuildinfo"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.turbo/**",
        "!dist/**",
        "!.svelte-kit/**",
        "!node_modules/.vite/**",
        "!tsconfig.tsbuildinfo"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.turbo/**",
        "!dist/**",
        "!.svelte-kit/**",
        "!node_modules/.vite/**",
        "!tsconfig.tsbuildinfo"
      ],
      "cache": false,
      "persistent": true
    },
    "preview": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    }
  }
}
