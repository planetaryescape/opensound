{
  "name": "opensound",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint -c oxlintrc.json --jest-plugin",
    "build": "turbo run build",
    "check": "turbo run check",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "docs": "turbo run dev --filter=@spotify-effect/docs",
    "spotify-docs": "turbo run dev --filter=@spotify-effect/docs",
    "frontpage": "turbo run dev --filter=@opensound/frontpage --filter=@spotify-effect/docs",
    "preview": "turbo run preview --filter=@opensound/frontpage --filter=@spotify-effect/docs",
    "test:watch": "bun run --filter @spotify-effect/core test:watch",
    "pc": "bun run fmt && bun run lint && bun run check && bun run typecheck && bun run build && bun run test",
    "example:basic": "turbo run build && SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 bun run examples/basic/src/main.ts",
    "example:browser": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 turbo run dev --filter=@examples/browser",
    "example:solid": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 turbo run dev --filter=@examples/solid",
    "example:sveltekit": "SPOTIFY_EFFECT_TRACE=1 OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:14318 turbo run dev --filter=@examples/sveltekit",
    "ci": "bun run lint && bun run check && bun run typecheck && bun run test && bun run build",
    "release": "changeset publish",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.81.0",
    "@types/node": "^25.6.0",
    "effect": "4.0.0-beta.36",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.60.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "packageManager": "bun@1.3.11"
}
